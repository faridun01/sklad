{
  "name": "sklad",
  "description": "Мой склад — Система управления розничной торговлей",
  "author": "Sklad Team",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server.ts",
    "dev:web": "vite --host 127.0.0.1 --port 3000 --strictPort",
    "build": "npm run type-check && vite build && npm run bundle-analysis",
    "build:prod": "cross-env NODE_ENV=production npm run build",
    "build:server": "node ./scripts/build-server.mjs",
    "bootstrap:admin": "node ./scripts/bootstrap-admin.mjs",
    "bundle-analysis": "node ./scripts/bundle-analyzer.mjs",
    "seed:demo": "node ./scripts/seed-sklad-demo.mjs",
    "check:stock": "node ./scripts/check-stock-integrity.mjs",
    "fix:stock": "node ./scripts/check-stock-integrity.mjs --fix",
    "check:duplicate-products": "node ./scripts/merge-duplicate-products.mjs",
    "fix:duplicate-products": "node ./scripts/merge-duplicate-products.mjs --apply",
    "preview": "vite preview",
    "clean": "rimraf dist dist-server",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "electron:dev": "node ./scripts/free-electron.mjs && node ./scripts/free-ports.mjs && concurrently --kill-others --success first \"npm run dev\" \"npm run dev:web\" \"cross-env NODE_ENV=development electron .\"",
    "electron:build": "node ./scripts/prepare-electron-build.mjs && node ./scripts/prepare-runtime-env.mjs && npm run build:prod && node ./scripts/prisma-generate-safe.mjs && npm run build:server && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder && node electron/launch-built.cjs",
    "test": "vitest",
    "analyze:bundle": "node ./scripts/bundle-size-check.cjs",
    "analyze:lighthouse": "node ./scripts/lighthouse-ci.js http://localhost:3000",
    "analyze:api": "node ./scripts/api-benchmark.cjs"
  },
  "build": {
    "appId": "com.sklad.app",
    "productName": "Sklad",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/runtime/.env",
        "to": ".env"
      }
    ],
    "asarUnpack": [
      "dist-server/**"
    ],
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron/**/*",
      "prisma/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "i18next": "^26.0.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prisma": "^6.16.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.4"
  }
}
