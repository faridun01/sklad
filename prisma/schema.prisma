// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/server/infrastructure/generated-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  CASHIER
  PHARMACIST
  WAREHOUSE_STAFF
}

enum ProductStatus {
  ACTIVE
  LOW_STOCK
  OUT_OF_STOCK
}

enum BatchStatus {
  CRITICAL
  STABLE
}

enum BatchMovementType {
  RESTOCK
  DISPATCH
  ADJUSTMENT
  RETURN
  WRITE_OFF
  TRANSFER_OUT
  TRANSFER_IN
}

enum PaymentType {
  CASH
  CARD
  CREDIT
  STORE_BALANCE
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceStatus {
  PAID
  PENDING
  CANCELLED
  RETURNED
  PARTIALLY_RETURNED
  RESERVED
}

enum ReturnType {
  CUSTOMER
  SUPPLIER
}

enum ReturnStatus {
  DRAFT
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum RefundMethod {
  CASH
  CARD
  STORE_BALANCE
}

enum WriteOffReason {
  EXPIRED
  DAMAGED
  LOST
  INTERNAL_USE
  MISMATCH
  BROKEN_PACKAGING
  OTHER
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  CASH_IN
  CASH_OUT
}

enum TransferStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum OcrDocumentStatus {
  UPLOADED
  PARSED
  MATCHED
  PARTIALLY_MATCHED
  NEEDS_REVIEW
  IMPORTED
  FAILED
  ROLLED_BACK
}

enum OcrConfidence {
  HIGH
  MEDIUM
  LOW
}

enum PriceType {
  PURCHASE
  WHOLESALE
  RETAIL
}

enum CounterpartyType {
  SUPPLIER
  OTHER
  CUSTOMER
}

enum PaymentDirection {
  IN
  OUT
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
}

enum PurchaseInvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum DebtStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  WRITTEN_OFF
}

model Product {
  id                String                @id @default(uuid())
  name              String
  sku               String                @unique
  barcode           String?               @unique
  internationalName String?
  category          String
  categoryId        String?
  productCategory   ProductCategory?      @relation(fields: [categoryId], references: [id])
  manufacturer      String
  countryOfOrigin   String?
  manufacturerId    String?
  manufacturerRef   Manufacturer?         @relation(fields: [manufacturerId], references: [id])
  dosage            String?
  dosageUnit        String?
  formId            String?
  form              ProductForm?          @relation(fields: [formId], references: [id])
  packageTypeId     String?
  packageType       PackageType?          @relation(fields: [packageTypeId], references: [id])
  totalStock        Int                   @default(0)
  minStock          Int                   @default(10)
  costPrice         Float
  sellingPrice      Float
  status            ProductStatus         @default(ACTIVE)
  isActive          Boolean               @default(true)
  image             String?
  prescription      Boolean               @default(false)
  markingRequired   Boolean               @default(false)
  analogs           String? // JSON string of analog product IDs or names
  batches           Batch[]
  warehouseStocks   WarehouseStock[]
  aliases           ProductAlias[]
  analogLinksFrom   ProductAnalog[]       @relation("ProductAnalogFrom")
  analogLinksTo     ProductAnalog[]       @relation("ProductAnalogTo")
  priceHistory      PriceHistory[]
  invoiceItems      InvoiceItem[]
  purchaseItems     PurchaseInvoiceItem[]
  returnItems       ReturnItem[]
  writeOffItems     WriteOffItem[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  StockTransferItem StockTransferItem[]
  OcrRow            OcrRow[]

  @@index([name])
  @@index([category])
}

model Batch {
  id               String               @id @default(uuid())
  batchNumber      String // The user-facing ID like #BAT-AMX-2024-001
  quantity         Int
  initialQty       Int                  @default(0)
  currentQty       Int                  @default(0)
  reservedQty      Int                  @default(0)
  availableQty     Int                  @default(0)
  unit             String
  costBasis        Float
  purchasePrice    Float?
  wholesalePrice   Float?
  retailPrice      Float?
  supplierId       String?
  supplier         Supplier?            @relation(fields: [supplierId], references: [id])
  warehouseId      String?
  warehouse        Warehouse?           @relation(fields: [warehouseId], references: [id])
  manufacturedDate DateTime
  receivedAt       DateTime             @default(now())
  expiryDate       DateTime
  status           BatchStatus
  productId        String
  product          Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseItemId   String?
  purchaseItem     PurchaseInvoiceItem? @relation(fields: [purchaseItemId], references: [id])
  movements        BatchMovement[]
  invoiceItems     InvoiceItem[]
  returnItems      ReturnItem[]
  writeOffItems    WriteOffItem[]
  transferItems    StockTransferItem[]
  reservations     Reservation[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([productId, expiryDate])
  @@index([batchNumber])
  @@index([status, expiryDate])
  @@index([productId, status])
}

model BatchMovement {
  id          String            @id @default(uuid())
  type        BatchMovementType
  quantity    Int
  date        DateTime          @default(now())
  description String?
  batchId     String
  batch       Batch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?             @relation(fields: [userId], references: [id])
}

model User {
  id                String            @id @default(uuid())
  username          String?
  email             String            @unique
  password          String
  name              String
  role              UserRole
  isActive          Boolean           @default(true)
  warehouseId       String?
  warehouse         Warehouse?        @relation(fields: [warehouseId], references: [id])
  lastLoginAt       DateTime?
  movements         BatchMovement[]
  invoices          Invoice[]
  purchaseInvoices  PurchaseInvoice[] @relation("PurchaseCreatedBy")
  payments          Payment[]
  auditLogs         AuditLog[]
  returnsCreated    Return[]          @relation("ReturnCreatedBy")
  returnsApproved   Return[]          @relation("ReturnApprovedBy")
  writeOffsCreated  WriteOff[]        @relation("WriteOffCreatedBy")
  writeOffsApproved WriteOff[]        @relation("WriteOffApprovedBy")
  shifts            CashShift[]       @relation("ShiftCashier")
  cashMovements     CashMovement[]
  ocrDocuments      OcrDocument[]     @relation("OcrUploadedBy")
  expenses          Expense[]         @relation("ExpenseRecordedBy")
  priceChanges      PriceHistory[]    @relation("PriceChangedBy")
  transfersCreated  StockTransfer[]   @relation("TransferCreatedBy")
  transfersReceived StockTransfer[]   @relation("TransferReceivedBy")
  ocrDraftApprovals OcrImportDraft[]  @relation("OcrDraftApprovedBy")
  backupsCreated    BackupMetadata[]  @relation("BackupCreatedBy")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Supplier {
  id               String            @id @default(uuid())
  name             String
  contact          String?
  email            String?
  address          String?
  contractNumber   String?
  contractDate     DateTime?
  paymentTermDays  Int?
  isActive         Boolean           @default(true)
  batches          Batch[]
  aliases          ProductAlias[]
  purchaseInvoices PurchaseInvoice[]
  payments         Payment[]
  ocrDocuments     OcrDocument[]
  payableEntries   SupplierPayable[]
  payables         Payable[]
  returns          Return[]          @relation("SupplierReturns")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([name])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNo     String        @unique
  customer      String?
  totalAmount   Float
  taxAmount     Float         @default(0)
  discount      Float         @default(0)
  paymentType   PaymentType
  status        InvoiceStatus @default(PAID)
  paymentStatus PaymentStatus @default(UNPAID)
  comment       String?
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  items         InvoiceItem[]
  payments      Payment[]
  returns       Return[]
  cashShiftId   String?
  cashShift     CashShift?    @relation(fields: [cashShiftId], references: [id])
  customerId    String?
  customerRef   Customer?     @relation(fields: [customerId], references: [id])
  receivable    Receivable?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}

model InvoiceItem {
  id             String  @id @default(uuid())
  invoiceId      String
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  batchId        String
  batch          Batch   @relation(fields: [batchId], references: [id])
  productName    String
  batchNo        String
  quantity       Int
  unitPrice      Float
  discountAmount Float   @default(0)
  totalPrice     Float

  @@index([invoiceId])
  @@index([productId])
  @@index([batchId])
  @@index([productId, batchId])
}

model AuditLog {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  userRole  UserRole?
  module    String?
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  reason    String?
  details   String? // JSON string of changes
  createdAt DateTime  @default(now())

  @@index([createdAt])
  @@index([module, action])
  @@index([userId])
}

model Warehouse {
  id               String            @id @default(uuid())
  code             String            @unique
  name             String
  type             String?
  address          String?
  isDefault        Boolean           @default(false)
  isActive         Boolean           @default(true)
  description      String?
  users            User[]
  batches          Batch[]
  stocks           WarehouseStock[]
  returns          Return[]
  writeOffs        WriteOff[]
  purchaseInvoices PurchaseInvoice[]
  shifts           CashShift[]
  transferOut      StockTransfer[]   @relation("TransferFromWarehouse")
  transferIn       StockTransfer[]   @relation("TransferToWarehouse")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  Expense          Expense[]
}

model WarehouseStock {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@index([productId])
}

model StockTransfer {
  id              String              @id @default(uuid())
  transferNo      String              @unique
  fromWarehouseId String
  fromWarehouse   Warehouse           @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse           @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  status          TransferStatus      @default(DRAFT)
  reason          String?
  createdById     String
  createdBy       User                @relation("TransferCreatedBy", fields: [createdById], references: [id])
  receivedById    String?
  receivedBy      User?               @relation("TransferReceivedBy", fields: [receivedById], references: [id])
  items           StockTransferItem[]
  createdAt       DateTime            @default(now())
  receivedAt      DateTime?
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  batchId    String?
  batch      Batch?        @relation(fields: [batchId], references: [id])
  quantity   Int

  @@index([transferId])
}

model Return {
  id           String        @id @default(uuid())
  returnNo     String        @unique
  type         ReturnType
  status       ReturnStatus  @default(DRAFT)
  warehouseId  String?
  warehouse    Warehouse?    @relation(fields: [warehouseId], references: [id])
  invoiceId    String?
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])
  supplierId   String?
  supplier     Supplier?     @relation("SupplierReturns", fields: [supplierId], references: [id])
  customerId   String?
  customer     Customer?     @relation(fields: [customerId], references: [id])
  customerName String?
  refundMethod RefundMethod?
  reason       String?
  note         String?
  totalAmount  Float?        @default(0)
  approvedById String?
  approvedBy   User?         @relation("ReturnApprovedBy", fields: [approvedById], references: [id])
  createdById  String
  createdBy    User          @relation("ReturnCreatedBy", fields: [createdById], references: [id])
  items        ReturnItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([type, status])
  @@index([createdAt])
}

model ReturnItem {
  id             String  @id @default(uuid())
  returnId       String
  return         Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  batchId        String?
  batch          Batch?  @relation(fields: [batchId], references: [id])
  quantity       Int
  unitPrice      Float?
  discountAmount Float?  @default(0)
  lineTotal      Float?  @default(0)
  reason         String?
  invoiceItemId  String?

  @@index([returnId])
}

model WriteOff {
  id           String         @id @default(uuid())
  writeOffNo   String         @unique
  warehouseId  String
  warehouse    Warehouse      @relation(fields: [warehouseId], references: [id])
  reason       WriteOffReason
  status       String         @default("POSTED")
  note         String?
  totalAmount  Float?         @default(0)
  createdById  String
  createdBy    User           @relation("WriteOffCreatedBy", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?          @relation("WriteOffApprovedBy", fields: [approvedById], references: [id])
  items        WriteOffItem[]
  createdAt    DateTime       @default(now())

  @@index([reason])
  @@index([createdAt])
}

model WriteOffItem {
  id         String   @id @default(uuid())
  writeOffId String
  writeOff   WriteOff @relation(fields: [writeOffId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  batchId    String?
  batch      Batch?   @relation(fields: [batchId], references: [id])
  quantity   Int
  unitCost   Float?   @default(0)
  lineTotal  Float?   @default(0)
}

model CashShift {
  id            String         @id @default(uuid())
  shiftNo       String         @unique
  warehouseId   String
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  cashierId     String
  cashier       User           @relation("ShiftCashier", fields: [cashierId], references: [id])
  status        ShiftStatus    @default(OPEN)
  openingCash   Float
  closingCash   Float?
  expectedCash  Float?
  discrepancy   Float?
  openAt        DateTime       @default(now())
  closeAt       DateTime?
  closeNote     String?
  invoices      Invoice[]
  cashMovements CashMovement[]

  @@index([cashierId, status])
  @@index([openAt])
}

model CashMovement {
  id        String           @id @default(uuid())
  shiftId   String
  shift     CashShift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      CashMovementType
  amount    Float
  reason    String
  createdAt DateTime         @default(now())
}

model PriceHistory {
  id            String    @id @default(uuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type          PriceType
  oldValue      Float?
  newValue      Float
  effectiveFrom DateTime
  changedById   String
  changedBy     User      @relation("PriceChangedBy", fields: [changedById], references: [id])
  note          String?
  createdAt     DateTime  @default(now())

  @@index([productId, type, effectiveFrom])
}

model ProductCategory {
  id        String            @id @default(uuid())
  name      String
  parentId  String?
  parent    ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("ProductCategoryTree")
  products  Product[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([name])
}

model Manufacturer {
  id        String    @id @default(uuid())
  name      String    @unique
  country   String?
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ProductForm {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PackageType {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PurchaseInvoice {
  id             String                @id @default(uuid())
  invoiceNumber  String                @unique
  supplierId     String
  supplier       Supplier              @relation(fields: [supplierId], references: [id])
  warehouseId    String
  warehouse      Warehouse             @relation(fields: [warehouseId], references: [id])
  invoiceDate    DateTime
  status         PurchaseInvoiceStatus @default(DRAFT)
  totalAmount    Float                 @default(0)
  discountAmount Float                 @default(0)
  taxAmount      Float                 @default(0)
  paymentStatus  PaymentStatus         @default(UNPAID)
  comment        String?
  createdById    String
  createdBy      User                  @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  items          PurchaseInvoiceItem[]
  payments       Payment[]
  payables       Payable[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([invoiceDate])
}

model PurchaseInvoiceItem {
  id                String          @id @default(uuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  batchNumber       String?
  manufacturedDate DateTime
  receivedAt       DateTime             @default(now())
  status           BatchStatus
  @@index([productId])
  total             Float           @default(0) // Сумма
  lineDiscount      Float           @default(0)
  lineTotal         Float           @default(0)
  batches           Batch[]

  @@index([purchaseInvoiceId])
  @@index([productId])
}

model Payment {
  id                String           @id @default(uuid())
  direction         PaymentDirection
  counterpartyType  CounterpartyType
  supplierId        String?
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])
  method            PaymentMethod
  amount            Float
  paymentDate       DateTime         @default(now())
  status            PaymentStatus    @default(PAID)
  referenceNumber   String?
  invoiceId         String?
  invoice           Invoice?         @relation(fields: [invoiceId], references: [id])
  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])
  createdById       String
  createdBy         User             @relation(fields: [createdById], references: [id])
  customerId        String?
  customer          Customer?        @relation(fields: [customerId], references: [id])
  comment           String?
  createdAt         DateTime         @default(now())

  @@index([paymentDate])
  @@index([invoiceId, paymentDate])
}

model Payable {
  id                String           @id @default(uuid())
  supplierId        String
  supplier          Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])
  originalAmount    Float
  paidAmount        Float            @default(0)
  remainingAmount   Float
  dueDate           DateTime?
  status            DebtStatus       @default(OPEN)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([supplierId, status])
}

model ProductAlias {
  id         String    @id @default(uuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  alias      String

  @@index([alias])
  @@index([productId])
}

model ProductAnalog {
  id              String  @id @default(uuid())
  productId       String
  product         Product @relation("ProductAnalogFrom", fields: [productId], references: [id], onDelete: Cascade)
  analogProductId String
  analogProduct   Product @relation("ProductAnalogTo", fields: [analogProductId], references: [id], onDelete: Cascade)
  similarityNote  String?

  @@unique([productId, analogProductId])
}

model OcrDocument {
  id             String            @id @default(uuid())
  documentNo     String            @unique
  supplierId     String?
  supplier       Supplier?         @relation(fields: [supplierId], references: [id])
  uploadedById   String
  uploadedBy     User              @relation("OcrUploadedBy", fields: [uploadedById], references: [id])
  fileName       String
  mimeType       String
  status         OcrDocumentStatus @default(UPLOADED)
  rawText        String?
  normalizedJson String?
  invoiceNumber  String?
  invoiceDate    DateTime?
  duplicateOfId  String?
  duplicateOf    OcrDocument?      @relation("OcrDuplicate", fields: [duplicateOfId], references: [id])
  duplicates     OcrDocument[]     @relation("OcrDuplicate")
  rows           OcrRow[]
  drafts         OcrImportDraft[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@index([invoiceNumber])
  @@index([createdAt])
}

model OcrRow {
  id               String        @id @default(uuid())
  documentId       String
  document         OcrDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  lineNo           Int
  rawLine          String?
  productName      String?
  sku              String?
  barcode          String?
  quantity         Float?
  unit             String?
  purchasePrice    Float?
  total            Float?
  batchNumber      String?
  // expiryDate removed
  matchedProductId String?
  matchedProduct   Product?      @relation(fields: [matchedProductId], references: [id])
  confidence       OcrConfidence @default(LOW)
  warnings         String?
  needsReview      Boolean       @default(true)
}

model OcrImportDraft {
  id           String      @id @default(uuid())
  documentId   String
  document     OcrDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  approvedById String?
  approvedBy   User?       @relation("OcrDraftApprovedBy", fields: [approvedById], references: [id])
  summary      String?
  imported     Boolean     @default(false)
  rolledBack   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model BackupMetadata {
  id          String   @id @default(uuid())
  fileName    String
  filePath    String
  checksum    String?
  sizeBytes   Int
  isAuto      Boolean  @default(false)
  status      String
  createdById String?
  createdBy   User?    @relation("BackupCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

model Expense {
  id           String     @id @default(uuid())
  category     String
  amount       Float
  note         String?
  warehouseId  String?
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  recordedById String
  recordedBy   User       @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
  date         DateTime   @default(now())

  @@index([date])
}

model SupplierPayable {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amount      Float
  type        String
  referenceNo String?
  note        String?
  createdAt   DateTime @default(now())

  @@index([supplierId, createdAt])
}

model Customer {
  id              String       @id @default(uuid())
  code            String?      @unique
  name            String
  legalName       String?
  phone           String?
  email           String?
  address         String?
  taxId           String?
  managerName     String?
  creditLimit     Float        @default(0)
  defaultDiscount Float        @default(0)
  paymentTermDays Int?
  isActive        Boolean      @default(true)
  invoices        Invoice[]
  receivables     Receivable[]
  returns         Return[]
  payments        Payment[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([name])
  @@index([code])
}

model Receivable {
  id              String     @id @default(uuid())
  invoiceId       String?    @unique
  invoice         Invoice?   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer?  @relation(fields: [customerId], references: [id])
  customerName    String?
  originalAmount  Float
  paidAmount      Float      @default(0)
  remainingAmount Float
  dueDate         DateTime?
  status          DebtStatus @default(OPEN)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([customerName, status])
  @@index([customerId])
}

model Reservation {
  id        String    @id @default(uuid())
  batchId   String
  batch     Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  quantity  Int
  status    String    @default("ACTIVE")
  // expiredAt removed
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([batchId])
}
